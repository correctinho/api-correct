# ==========================================
# TAXIMACHINE - INTEGRAÇÃO DE ENTREGAS
# ==========================================

# URL base da API 
TAXIMACHINE_API_URL="https://api.taximachine.com.br"

# A chave estática gerada no painel (Configuração > Integrações > Machine API)
TAXIMACHINE_API_KEY="sua_chave_de_api_aqui"

# O ID único da Correct Digital dentro da TaxiMachine
TAXIMACHINE_EMPRESA_ID="1234"

# Chave secreta inventada por nós para validar se o Webhook veio mesmo deles
TAXIMACHINE_WEBHOOK_SECRET="uma_senha_muito_segura_e_aleatoria_aqui"

# Tempo em que o valor calculado pelo frete vai se manter até a próxima alteração
FREIGHT_QUOTE_TTL_MINUTES=15